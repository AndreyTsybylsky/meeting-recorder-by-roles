{
  "manifest_version": 3,
  "name": "Meet Transcriber",
  "version": "1.4",
  "description": "Records Google Meet closed captions and saves them to a text file.",
  "permissions": [
    "storage",
    "tabs",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Transcriber — Сессии",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://meet.google.com/*", "*://teams.microsoft.com/*", "*://teams.live.com/*", "*://teams.cloud.microsoft/*", "*://zoom.us/*", "*://*.zoom.us/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["*://meet.google.com/*"],
      "js": ["googlemeet-capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://teams.microsoft.com/*", "*://teams.live.com/*", "*://teams.cloud.microsoft/*"],
      "js": ["teams-capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
