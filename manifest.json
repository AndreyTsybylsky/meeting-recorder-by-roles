{
  "manifest_version": 3,
  "name": "Meet Transcriber",
  "version": "1.1",
  "description": "Records Google Meet closed captions and saves them to a text file.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Transcriber — Сессии"
  },
  "content_scripts": [
    {
      "matches": ["*://meet.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
